{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@api/*": ["src/api/*"],
      "@generators/*": ["src/generators/*"],
      "@services/*": ["src/services/*"],
      "@config/*": ["src/config/*"],
      "@utils/*": ["src/utils/*"],
      "@interface/*": ["src/interface/*"],
      "@themes/*": ["src/themes/*"],
      "@data/*": ["src/data/*"],
      "@cache/*": ["src/cache/*"]
    },
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": [
    "src/**/*",
    "profile.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
